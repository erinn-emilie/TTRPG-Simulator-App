<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>2f3b96d5-6e89-4e1a-808a-57a53a8dcf4f</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>TTRPG_Simulator_App.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>TTRPG Simulator App</Name>
    <RootNamespace>TTRPG Simulator App</RootNamespace>
    <InterpreterId>MSBuild|env|$(MSBuildProjectFullPath)</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="enums\MapLoadLocations.py" />
    <Compile Include="enums\SettlementTypes.py" />
    <Compile Include="enums\TileSizeUnits.py" />
    <Compile Include="enums\TokenTypes.py" />
    <Compile Include="pages\GridWindow.py" />
    <Compile Include="toolbox\Logger.py" />
    <Compile Include="toolbox\SavedMaps.py" />
    <Compile Include="TokenRecord.py" />
    <Compile Include="toolbox\HextileMap.py" />
    <Compile Include="HextileNode.py" />
    <Compile Include="enums\MapSizes.py" />
    <Compile Include="enums\TileGenerationTypes.py" />
    <Compile Include="pages\CustomTokenExploreWindow.py" />
    <Compile Include="pages\HomeWindow.py" />
    <Compile Include="toolbox\Seed.py" />
    <Compile Include="toolbox\Settings.py" />
    <Compile Include="widgets\diceroll.py" />
    <Compile Include="widgets\LogWidget.py" />
    <Compile Include="widgets\SettingsMenu.py" />
    <Compile Include="TileRecord.py" />
    <Compile Include="toolbox\TileTypes.py" />
    <Compile Include="toolbox\Tokens.py" />
    <Compile Include="toolbox\Toolbox.py" />
    <Compile Include="TTRPG_Login_Window.py" />
    <Compile Include="TTRPG_Simulator_App.py" />
    <Compile Include="widgets\GenericContainerWidget.py" />
    <Compile Include="widgets\TileChangeMessageBox.py" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="jsonfiles\Animals.json" />
    <Content Include="jsonfiles\Buildings.json" />
    <Content Include="jsonfiles\Monsters.json" />
    <Content Include="jsonfiles\Nature.json" />
    <Content Include="jsonfiles\NonPlayerCharacters.json" />
    <Content Include="jsonfiles\PlayerCharacters.json" />
    <Content Include="jsonfiles\SavedMaps.json" />
    <Content Include="jsonfiles\Structures.json" />
    <Content Include="jsonfiles\TileTypes.json" />
    <Content Include="logfiles\TemporaryLog.txt" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="enums\" />
    <Folder Include="jsonfiles\" />
    <Folder Include="logfiles\" />
    <Folder Include="toolbox\" />
    <Folder Include="widgets\" />
    <Folder Include="pages\" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="env\">
      <Id>env</Id>
      <Version>3.14</Version>
      <Description>env (Python 3.14.3)</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
